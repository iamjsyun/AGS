# test_stale_session_cleanup.tsd
SCENARIO: SCEN_STALE_CLEANUP_01 : "Stale Orphan DB Record Garbage Collection"
DEFINE: SYMBOL=Gold#, CNO=1008, SNO=01, GNO=01, DIR=1, TYPE=0

PRICER: Gold# > TREND : trend_slope=0.0, jump_prob=0.0, start=2350.00, spread=20

TICK: 1   > INJECT: signals : xa_entry=1, xa_exit=0, price_signal=2350.00, \
                              cno=1008, sno=01, dir=1, type=0, lot=0.1, \
                              xe_status=10, ticket=99008
# 단말 자산 목록에서 99008을 완전 증발시킴
TICK: 2   > INJECT: terminal: order_fill=false, ticket=0
# 300초 경과 모의 (TICK 30에 준하는 경과 또는 시간차 주입)
TICK: 30  > MARKET: Gold#  : price=2350.00
          ? EXPECT: session : state=SYS_CLOSED * xe_status=XE_CLOSED_SIGNAL
