#==================================================================
# ATSE Scenario: Broker Reject Entry (v1.0)
# Covers: Signal Injection -> Broker Rejects -> Error State -> Rollback
#==================================================================

SCENARIO: SCEN_RES_BROKER_REJECT : "Broker Rejection Recovery"
DEFINE: SYMBOL=Gold#, CNO=1011, SNO=01, GNO=01, DIR=1, TYPE=0

PRICER: Gold# > TREND : start=2350.00

# Tick 1: Inject signal
TICK: 1   > INJECT: signals : xa_entry=1, price_signal=2350.00, \
                              cno=1011, yymmddhh=26052806, sno=01, gno=01, dir=1, type=0
          ? EXPECT: session : state=ORD_READY

# Tick 2: Fail the next trade request
TICK: 2   > FAIL: broker : next=true
          ? EXPECT: session : xe_status=99 ! FAIL_MSG: "Engine failed to transit to ERROR state after broker rejection"

# Tick 3: System should allow retry or mark as dead.
# In our system, XE_ERROR might be cleaned up or require manual intervention.
TICK: 3   ? EXPECT: terminal : ticket=0, exists=false
