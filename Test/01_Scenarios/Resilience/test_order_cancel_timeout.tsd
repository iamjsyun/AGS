# test_order_cancel_timeout.tsd
SCENARIO: SCEN_ORDER_TIMEOUT_01 : "Order Cancellation Timeout & Recovery"
DEFINE: SYMBOL=GOLD#, CNO=1004, SNO=01, GNO=01, DIR=1, TYPE=0

PRICER: GOLD# > TREND : trend_slope=0.0, jump_prob=0.0, start=2350.00, spread=20

TICK: 1   > INJECT: signals : xa_entry=1, xa_exit=1, price_signal=2350.00, \
                              cno=1004, sno=01, dir=1, type=0, lot=0.1
TICK: 2   > INJECT: terminal: order_fill=true, ticket=88004
          ? EXPECT: session : state=SESSION_LIQUIDATING

# 브로커가 지속 실패하도록 설정
TICK: 3   > FAIL  : broker  : next=true
TICK: 30  > MARKET: GOLD#  : price=2350.00
          ? EXPECT: session : state=SYS_CLOSED * xe_status=XE_ERROR
