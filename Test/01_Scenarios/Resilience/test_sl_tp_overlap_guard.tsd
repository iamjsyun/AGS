# test_sl_tp_overlap_guard.tsd
SCENARIO: SCEN_SL_TP_OVERLAP_01 : "SL/TP Price Configuration Overlap Protection"
DEFINE: SYMBOL=GOLD#, CNO=1009, SNO=01, GNO=01, DIR=1, TYPE=0

PRICER: GOLD# > TREND : trend_slope=0.0, jump_prob=0.0, start=2350.00, spread=20

# BUY 오더인데 SL을 시장가보다 높은 2400.00으로 비정상 주입
TICK: 1   > INJECT: signals : xa_entry=1, xa_exit=0, price_signal=2350.00, \
                              cno=1009, sno=01, dir=1, type=0, lot=0.1, \
                              sl=240000, tp=10000
          ? EXPECT: session : state=SYS_ERROR * xe_status=XE_ERROR
