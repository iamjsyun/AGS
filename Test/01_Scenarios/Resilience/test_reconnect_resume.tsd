# test_reconnect_resume.tsd
SCENARIO: SCEN_RECONNECT_RESUME_01 : "Broker Reconnection Trailing Session Resume Guard"
DEFINE: SYMBOL=GOLD#, CNO=1006, SNO=01, GNO=01, DIR=1, TYPE=0

PRICER: GOLD# > TREND : trend_slope=0.0, jump_prob=0.0, start=2350.00, spread=20

TICK: 1   > INJECT: signals : xa_entry=1, xa_exit=0, price_signal=2350.00, \
                              cno=1006, sno=01, dir=1, type=0, lot=0.1, ts_start=2000, ts_step=500
TICK: 2   > INJECT: terminal: order_fill=true, ticket=88006
          ? EXPECT: session : state=POS_MONITORING

# 2375.00 도달하여 익트(State 15) 진입
TICK: 3   > MARKET: GOLD#  : price=2375.00
          ? EXPECT: session : state=POS_TRAILING

# 통신 끊김 모의
TICK: 4   > FAIL  : broker  : next=true
TICK: 5   > MARKET: GOLD#  : price=2380.00
          ? EXPECT: session : state=POS_TRAILING

# 통신 복구
TICK: 6   > FAIL  : broker  : next=false
TICK: 7   > MARKET: GOLD#  : price=2381.00
          ? EXPECT: session : state=POS_TRAILING
