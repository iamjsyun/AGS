#==================================================================
# [Unit Scenario] Normal Entry & Binding v2.0
# Description: Standard market entry and physical asset binding
#==================================================================

SCENARIO: SCEN_ENTRY_NORMAL_V2 : "Normal Entry & Physical Binding v2.0"
DEFINE: SYMBOL=Gold#, CNO=5001, SNO=01, GNO=01, DIR=1, TYPE=1, LOT=0.1

PRICER: Gold# > TREND : trend_slope=0.0, start=2000.00, spread=20

# T1: Discovery
TICK: 1   > INJECT: signals : xa_entry=1, xa_exit=0, price_signal=2000.00, \
                              cno=5001, yymmddhh=26053115, sno=01, gno=01, dir=1, type=1, \
                              lot=0.1
          ? EXPECT: session : state=ORD_READY

# T2: Validation - Risk & Price check
TICK: 2   ? EXPECT: signal  : cno=5001 * status=XE_READY

# T3: Execution - Broker Call
TICK: 3   > INJECT: terminal: order_fill=false, ticket=88501
          ? EXPECT: session : state=ORD_TRAILING * xe_status=XE_PENDING_PLACED

# T4: Virtual Market Change
TICK: 4   > MARKET: Gold#  : price=1999.50
          ? EXPECT: session : state=ORD_TRAILING

# T5: Binding - Order Filled
TICK: 5   > INJECT: terminal: order_fill=true, ticket=88501
          ? EXPECT: session : state=POS_ACTIVE * xe_status=XE_EXECUTED
