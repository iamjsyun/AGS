#==================================================================
# ATSE Scenario: Duplicate SID (v1.1)
# Covers: Signal Injection -> Duplicate Signal Injection -> Integrity Maintained
#==================================================================

SCENARIO: SCEN_DUP_INJECT_01 : "Duplicate SID Block"
DEFINE: SYMBOL=GOLDF#, CNO=1003, SNO=01, GNO=01, DIR=1, TYPE=0

PRICER: GOLDF# > TREND : trend_slope=0.0, jump_prob=0.0, start=2350.00, spread=20

# Tick 1: Inject first signal
TICK: 1   > INJECT: signals : xa_entry=1, xa_exit=0, price_signal=2350.00, \
                              cno=1003, yymmddhh=26052804, sno=01, gno=01, dir=1, type=0
          ? EXPECT: session : state=ORD_READY

# Tick 2: Inject duplicate signal with same parameters but different price
TICK: 2   > INJECT: signals : xa_entry=1, xa_exit=0, price_signal=2390.00, \
                              cno=1003, yymmddhh=26052804, sno=01, gno=01, dir=1, type=0
          ? EXPECT: session : state=ORD_READY ! FAIL_MSG: "Duplicate SID injection corrupted the session"
