#==================================================================
# [Unit Scenario] Duplicate SID Protection v2.0
# Description: Verifies that duplicate SID signals are rejected
#==================================================================

SCENARIO: SCEN_ENTRY_DUP_SID_V2 : "Duplicate SID Protection v2.0"
DEFINE: SYMBOL=GOLD#, CNO=7001, SNO=01, GNO=01, DIR=1, TYPE=1, LOT=0.1, SID="7001-26053115-01-01-1-1"

PRICER: GOLD# > TREND : start=2000.00, spread=20

# T1: Discovery of first signal
TICK: 1   > INJECT: signals : xa_entry=1, cno=7001, sid="7001-26053115-01-01-1-1"
          ? EXPECT: session : state=ORD_READY

# T2: First signal moves to execution
TICK: 2   > INJECT: terminal: order_fill=false, ticket=88701
          ? EXPECT: session : state=ORD_TRAILING

# T3: Discovery of DUPLICATE signal (Same SID)
TICK: 3   > INJECT: signals : xa_entry=1, cno=7002, sid="7001-26053115-01-01-1-1"
          ? EXPECT: session : state=ORD_TRAILING

# T4: Guard check - Second signal should remain READY or move to ERROR (logic dependent)
# Currently, CXAssetManager::ExecuteEntry rejects it and logs error
TICK: 4   ? EXPECT: signal : cno=7001 * xe_status=XE_PENDING_PLACED

# T5: Final - Ensure first session is untouched
TICK: 5   ? EXPECT: session : state=ORD_TRAILING
