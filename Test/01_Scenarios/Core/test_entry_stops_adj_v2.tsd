#==================================================================
# [Unit Scenario] Entry Price Adjustment (StopsLevel) v2.0
# Description: Verifies that entry price is adjusted when too close to market
#==================================================================

SCENARIO: SCEN_ENTRY_STOPS_ADJ_V2 : "Entry Price Adjustment (StopsLevel) v2.0"
DEFINE: SYMBOL=Gold#, CNO=3001, SNO=01, GNO=01, DIR=1, TYPE=1, LOT=0.1

PRICER: Gold# > TREND : trend_slope=0.0, jump_prob=0.0, start=2000.00, spread=20

# T1: Discovery
TICK: 1   > INJECT: signals : xa_entry=1, xa_exit=0, price_signal=2000.00, \
                              cno=3001, yymmddhh=26053114, sno=01, gno=01, dir=1, type=1, \
                              lot=0.1, te_start=5, te_step=5, te_limit=10
          ? EXPECT: session : state=ORD_READY

# T2: Validation & Adjustment
# Current Ask is 2000.10 (spread 20). te_start 5 pts = 0.05. Trigger at 2000.05.
# If StopsLevel is high (e.g. 50), the validator should adjust the limit price down.
TICK: 2   ? EXPECT: signal  : cno=3001

# T3: Execution with Adjusted Price
TICK: 3   > INJECT: terminal: order_fill=false, ticket=88301
          ? EXPECT: session : state=ORD_TRAILING

# T4: Virtual Price Move
TICK: 4   > MARKET: Gold#  : price=1999.00
          ? EXPECT: session : state=ORD_TRAILING

# T5: Binding Check
TICK: 5   > INJECT: terminal: order_fill=true, ticket=88301
          ? EXPECT: session : state=POS_ACTIVE * xe_status=XE_EXECUTED
