#==================================================================
# ATSE Scenario: Slippage Control (v1.0)
# Covers: Limit Signal -> Market Price Moves Away -> Price Correction
#==================================================================

SCENARIO: SCEN_TRADE_SLIPPAGE_CONTROL : "Slippage Control and Correction"
DEFINE: SYMBOL=GOLDF#, CNO=1010, SNO=01, GNO=01, DIR=1, TYPE=2

PRICER: GOLDF# > TREND : start=2350.00, spread=20

# Tick 1: Inject Limit signal at 2350.00
TICK: 1   > INJECT: signals : xa_entry=1, price_signal=2350.00, \
                              cno=1010, yymmddhh=26052805, sno=01, gno=01, dir=1, type=2
          ? EXPECT: session : state=ORD_READY

# Tick 2: Market price jumps to 2355.00 (Limit Buy at 2350.00 is now far)
TICK: 2   > MARKET: price : price=2355.00
          ? EXPECT: session : state=ORD_READY

# Tick 3: Attempt to execute (But PriceManager should notice slippage)
# This scenario assumes the engine would modify or reject if slippage is too high,
# or simply verify that it stays in ORD_READY until price returns.
TICK: 3   > MARKET: price : price=2350.10
          > INJECT: terminal: order_fill=true, ticket=111101, price=2350.10
          ? EXPECT: session : state=POS_ACTIVE
