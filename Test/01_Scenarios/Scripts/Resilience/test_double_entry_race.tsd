#==================================================================
# ATSE Scenario: Double Entry Race (v1.0)
# Covers: Two signals for same symbol/magic injected rapidly
#==================================================================

SCENARIO: SCEN_RES_DOUBLE_ENTRY : "Double Entry Race Condition"
DEFINE: SYMBOL=GOLDF#, CNO=1012, SNO=01, GNO=01, DIR=1, TYPE=0

PRICER: GOLDF# > TREND : start=2350.00

# Tick 1: Inject two signals with different SNO but same Symbol/Dir
TICK: 1   > INJECT: signals : xa_entry=1, price_signal=2350.00, \
                              cno=1012, yymmddhh=26052807, sno=01, gno=01, dir=1, type=0
          > INJECT: signals : xa_entry=1, price_signal=2350.00, \
                              cno=1012, yymmddhh=26052807, sno=02, gno=01, dir=1, type=0
          
          # Both should be ready
          ? EXPECT: session : sid="1012-26052807-01-01-1-0", state=ORD_READY
          ? EXPECT: session : sid="1012-26052807-02-01-1-0", state=ORD_READY

# Tick 2: One gets filled
TICK: 2   > INJECT: terminal: order_fill=true, ticket=22201, sid="1012-26052807-01-01-1-0"
          ? EXPECT: session : sid="1012-26052807-01-01-1-0", state=POS_ACTIVE
          ? EXPECT: session : sid="1012-26052807-02-01-1-0", state=ORD_READY
