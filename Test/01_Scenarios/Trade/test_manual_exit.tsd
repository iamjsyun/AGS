#==================================================================
# ATSE Scenario: Manual Exit (v1.1)
# Covers: Entry -> Execution -> Manual Close -> Fast-Track Closed
#==================================================================

SCENARIO: SCEN_MANUAL_EXIT_01 : "Manual Exit Fast-Track Detection"
DEFINE: SYMBOL=GOLD#, CNO=1001, SNO=01, GNO=01, DIR=1, TYPE=0

PRICER: GOLD# > TREND : trend_slope=0.0, jump_prob=0.0, start=2350.00, spread=20

# Tick 1: Inject signal and spawn session
TICK: 1   > INJECT: signals : xa_entry=1, xa_exit=0, price_signal=2350.00, \
                              cno=1001, yymmddhh=26052804, sno=01, gno=01, dir=1, type=0, lot=0.1
          ? EXPECT: session : state=ORD_READY

# Tick 2: Position filled
TICK: 2   > INJECT: terminal: order_fill=true, ticket=55555
          ? EXPECT: session : state=POS_ACTIVE * xe_status=XE_EXECUTED

# Tick 3: Position disappeared manually (zapped from terminal)
TICK: 3   > INJECT: terminal: order_fill=false, ticket=0
          ? EXPECT: session : state=SYS_CLOSED * xe_status=XE_CLOSED_MANUAL ! FAIL_MSG: "Failed to trigger manual close fast-track"
