#==================================================================
# ATSE Scenario: Advanced Exit Resilience (v1.0)
# Covers: Scenarios E, F, G, H
#==================================================================

SCENARIO: SCEN_ADV_EXIT_RESILIENCE : "Advanced Exit Resilience (E, F, G, H)"
DEFINE: SYMBOL=Gold#, CNO=1001, SNO=99, GNO=01, DIR=1, TYPE=0, SID="1001-26052812-99-01-1-0", MAGIC=1001

PRICER: Gold# > TREND : trend_slope=0.0, start=2350.00, spread=20

#--- [SCENARIO H: Manual Drift Sync] ---
# Tick 1: Inject position in terminal with SL=2340, while signal (not yet injected) would have 2350.
TICK: 1   > INJECT: terminal: order_fill=true, ticket=77701, sid="1001-26052812-99-01-1-0", sl=2340.0, price=2350.0
          > INJECT: signals : sid="1001-26052812-99-01-1-0", cno=1001, sno=99, xe_status=10, xa_exit=0, lot=0.1
          ? EXPECT: session : sid="1001-26052812-99-01-1-0", xe_status=XE_EXECUTED

# Tick 2: Trigger Exit (xa_exit=1). CXTaskExit_R_Order should call SyncToSignal.
TICK: 2   > INJECT: signals : sid="1001-26052812-99-01-1-0", xa_exit=1
          ? EXPECT: session : sid="1001-26052812-99-01-1-0", xe_status=XE_CLOSED_SIGNAL
          ? EXPECT: terminal : ticket=77701, exists=false

#--- [SCENARIO E: Partial Fill Sweep] ---
# Tick 10: Inject asset with different ticket but SAME SID.
TICK: 10  > INJECT: terminal: order_fill=true, ticket=88801, sid="1001-26052812-88-01-1-0", price=2350.0
          > INJECT: signals : sid="1001-26052812-88-01-1-0", cno=1001, sno=88, xe_status=10, xa_exit=0
          ? EXPECT: terminal : ticket=88801, exists=true

# Tick 11: Trigger Exit for SID 88. Even if signal has ticket 0 or mismatch, SweepBySid should find it.
TICK: 11  > INJECT: signals : sid="1001-26052812-88-01-1-0", xa_exit=1
          ? EXPECT: terminal : ticket=88801, exists=false

#--- [SCENARIO F: Broker Offline Recovery] ---
# Tick 20: Inject position and prepare for exit.
TICK: 20  > INJECT: terminal: order_fill=true, ticket=66601, sid="1001-26052812-66-01-1-0", price=2350.0
          > INJECT: signals : sid="1001-26052812-66-01-1-0", cno=1001, sno=66, xe_status=10, xa_exit=0

# Tick 21: Set Broker to FAIL. Trigger exit. Should remain EXECUTED (because retry loop).
TICK: 21  > FAIL: broker : next=true
          > INJECT: signals : sid="1001-26052812-66-01-1-0", xa_exit=1
          ? EXPECT: session : sid="1001-26052812-66-01-1-0", xe_status=XE_EXECUTED
          ? EXPECT: terminal : ticket=66601, exists=true

# Tick 22: Broker OK. Should close now.
TICK: 22  ? EXPECT: session : sid="1001-26052812-66-01-1-0", xe_status=XE_CLOSED_SIGNAL
          ? EXPECT: terminal : ticket=66601, exists=false

#--- [SCENARIO G: Massive Zombie Re-sweep] ---
# Tick 30: Inject 5 signals with xa_exit=1
TICK: 30  > INJECT: signals : sid="SID-G1", cno=1001, sno=101, xe_status=10, xa_exit=1
          > INJECT: signals : sid="SID-G2", cno=1001, sno=102, xe_status=10, xa_exit=1
          > INJECT: signals : sid="SID-G3", cno=1001, sno=103, xe_status=10, xa_exit=1
          > INJECT: signals : sid="SID-G4", cno=1001, sno=104, xe_status=10, xa_exit=1
          > INJECT: signals : sid="SID-G5", cno=1001, sno=105, xe_status=10, xa_exit=1
          # Also inject them in terminal as zombies
          > INJECT: terminal : ticket=101, sid="SID-G1"
          > INJECT: terminal : ticket=102, sid="SID-G2"
          > INJECT: terminal : ticket=103, sid="SID-G3"
          > INJECT: terminal : ticket=104, sid="SID-G4"
          > INJECT: terminal : ticket=105, sid="SID-G5"
          
# Tick 31: Watcher should detect 5 signals and trigger SweepByMagic.
TICK: 31  ? EXPECT: terminal : ticket=101, exists=false
          ? EXPECT: terminal : ticket=105, exists=false
