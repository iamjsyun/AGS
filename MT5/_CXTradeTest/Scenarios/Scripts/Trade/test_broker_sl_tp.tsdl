#==================================================================
# ATSE Scenario: Broker SL/TP close (v1.1)
# Covers: Active Position -> Price moves past SL -> Broker SL Trigger -> Closed SL
#==================================================================

SCENARIO: SCEN_BROKER_SL_TP_01 : "Broker SL Triggered Close"
DEFINE: SYMBOL=GOLDF#, CNO=1009, SNO=01, GNO=01, DIR=1, TYPE=0

PRICER: GOLDF# > TREND : trend_slope=0.0, jump_prob=0.0, start=2350.00, spread=20

# Tick 1: Inject signal with SL (5000 points = $50.00) and TP (10000 points = $100.00)
TICK: 1   > INJECT: signals : xa_entry=1, xa_exit=0, cno=1009, yymmddhh=26052804, sno=01, gno=01, dir=1, type=0, \
                              sl=5000, tp=10000, price_signal=2350.00
TICK: 2   > INJECT: terminal: order_fill=true, ticket=22222
          ? EXPECT: session : state=POS_ACTIVE

# Tick 3: Price moves down (2290.00). This crosses the SL price (2300.00).
# The mock broker triggers SL close, and the engine detects it.
TICK: 3   > MARKET: GOLDF#  : price=2290.00
          ? EXPECT: session : state=SYS_CLOSED * xe_status=XE_CLOSED_SL ! FAIL_MSG: "Failed to detect SL hit and close session with XE_CLOSED_SL"
