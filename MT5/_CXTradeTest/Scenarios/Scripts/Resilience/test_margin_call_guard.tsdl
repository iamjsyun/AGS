# test_margin_call_guard.tsdl
SCENARIO: SCEN_MARGIN_GUARD_01 : "Margin/Lot Safety Guard Rejection Validation"
DEFINE: SYMBOL=GOLDF#, CNO=1005, SNO=01, GNO=01, DIR=1, TYPE=0

PRICER: GOLDF# > TREND : trend_slope=0.0, jump_prob=0.0, start=2350.00, spread=20

TICK: 1   > INJECT: signals : xa_entry=1, xa_exit=0, price_signal=2350.00, \
                              cno=1005, sno=01, dir=1, type=0, lot=60.0
          ? EXPECT: session : state=SYS_ERROR * xe_status=XE_ERROR
